# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
APP_ENV=development
ENABLE_LIVE_INTEGRATIONS=false

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=opportunity_memory
VECTOR_SIZE=384

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

POSTGRES_PASSWORD=
DATABASE_URL=postgresql+psycopg://postgres:<password>@localhost:5432/magneticsphere
REDIS_URL=redis://localhost:6379/0

SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
HUBSPOT_ACCESS_TOKEN=
# Optional alias for older/local naming. Prefer HUBSPOT_ACCESS_TOKEN for new setup.
HUBSPOT_API_KEY=
HUBSPOT_BASE_URL=https://api.hubapi.com

GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

NEWS_API_KEY=
NEWS_API_URL=https://newsapi.org/v2/everything
NEWS_API_PAGE_SIZE=20
EXTERNAL_REQUEST_TIMEOUT=2
NEWS_RSS_FEEDS=https://techcrunch.com/tag/artificial-intelligence/feed/,https://www.prnewswire.com/news-releases/news-releases-list.rss
TARGET_KEYWORDS=AI,MLOps,cloud AI,automation,healthcare AI,computer vision,funding,hiring
TARGET_COMPANIES_JSON=[{"name":"OpenAI","domain":"openai.com","industry":"Artificial Intelligence"},{"name":"Anthropic","domain":"anthropic.com","industry":"Artificial Intelligence"},{"name":"Perplexity","domain":"perplexity.ai","industry":"AI Search"},{"name":"Cursor","domain":"cursor.com","industry":"AI Developer Tools"},{"name":"Reddit","domain":"reddit.com","industry":"Social Media"},{"name":"Google Gemini","domain":"gemini.google.com","industry":"Artificial Intelligence"},{"name":"OpenCV","domain":"opencv.org","industry":"Computer Vision"},{"name":"Microsoft","domain":"microsoft.com","industry":"Cloud and AI"},{"name":"Notion","domain":"notion.so","industry":"Productivity Software"}]
